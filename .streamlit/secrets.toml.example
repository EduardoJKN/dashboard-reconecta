# =============================================================================
# Reconecta BI — secrets.toml (TEMPLATE)
# =============================================================================
# COMO USAR
#
#  Local (opcional — só se quiser testar com st.secrets antes do deploy):
#    1. Copie este arquivo para .streamlit/secrets.toml
#    2. Substitua os valores pelos reais
#    3. NÃO faça commit — o .gitignore já bloqueia secrets.toml
#
#  Produção (Streamlit Community Cloud):
#    1. Em https://share.streamlit.io abra o app
#    2. ⋯ → Settings → Secrets
#    3. Cole o conteúdo COMPLETO deste arquivo no painel (com valores reais)
#    4. Salve — o app reinicia automaticamente
#
# Não comite secrets.toml em hipótese alguma.
# =============================================================================

[postgres]
host     = "seu-host-postgres.example.com"
port     = "5432"
database = "nome_do_banco"
user     = "usuario_readonly"
password = "TROQUE_POR_SENHA_REAL"
sslmode  = "require"

[auth]
# Senha compartilhada para acessar o dashboard.
# Troque para algo forte (>=16 chars, mistura de letras, números e símbolos).
# Trocar a senha bloqueia novos logins; quem já tem cookie válido continua
# até o cookie expirar (ou até `cookie_key` mudar — ver abaixo).
password = "TROQUE_PARA_UMA_SENHA_FORTE"

# Chave HMAC usada para assinar o JWT do cookie de sessão.
# Mínimo 32 chars aleatórios. Para gerar:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# Trocar essa chave invalida instantaneamente todos os cookies existentes
# (logout global). Use isso para revogar acesso de todos.
cookie_key = "TROQUE_PARA_UMA_CHAVE_ALEATORIA_LONGA_MIN_32_CHARS"

# Validade do cookie de sessão em dias. Default = 7 quando omitido.
# Aumentar para 30 etc. quando quiser sessões mais longas.
cookie_expiry_days = 7

# Senha para editar/salvar metas no Funil da Reconecta (independente do login geral).
# Também aceito como chave top-level: METAS_EDITOR_PASSWORD = "..."
metas_editor_password = "definir_senha_do_editor_de_metas"

# URL completa do Postgres de metas (Funil da Reconecta).
# Usada só para bi.metas_funil_reconecta e bi.vw_metas_funil_reconecta.
METAS_DATABASE_URL = "postgresql+psycopg2://usuario:senha@host:5432/banco?sslmode=require"

# Alternativa top-level (mesmo efeito que auth.metas_editor_password):
METAS_EDITOR_PASSWORD = "definir_senha_do_editor_de_metas"
